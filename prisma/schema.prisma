generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider          = "mysql"
  url               = env("DATABASE_CON_URL")
  shadowDatabaseUrl = env("DATABASE_CON_URL_SHADOW")
}

model Participant {
  id               Int               @id @default(autoincrement())
  name             String
  origin           String
  trip_participant TripParticipant[]

  @@unique([name, origin])
}

model TripParticipant {
  id             Int         @id @default(autoincrement())
  participant_id Int
  trip_id        BigInt      @db.UnsignedBigInt
  answers        String
  report_date    DateTime    @default(now())
  participant    Participant @relation(fields: [participant_id], references: [id])
  trip           wp_posts    @relation(fields: [trip_id], references: [ID])

  @@index([participant_id], map: "TripParticipant_participant_id_fkey")
  @@index([trip_id], map: "TripParticipant_trip_id_fkey")
}

model Account {
  id                       String   @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?  @db.Text
  access_token             String?  @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?  @db.Text
  session_state            String?
  createdAt                DateTime @default(now())
  refresh_token_expires_in Int?
  updatedAt                DateTime @default(now()) @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @default(now()) @updatedAt
  username      String?         @unique
  accounts      Account[]
  Authenticator Authenticator[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model wp_postmeta {
  meta_id    BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  post_id    BigInt  @default(0) @db.UnsignedBigInt
  meta_key   String? @db.VarChar(255)
  meta_value String? @db.LongText

  @@index([meta_key(length: 191)], map: "meta_key")
  @@index([post_id], map: "post_id")
  @@index([post_id, meta_key(length: 191)], map: "post_id_meta_key")
}

model wp_posts {
  ID                    BigInt            @id @default(autoincrement()) @db.UnsignedBigInt
  post_author           BigInt            @default(0) @db.UnsignedBigInt
  post_date             DateTime?         @db.DateTime(0)
  post_date_gmt         DateTime?         @db.DateTime(0)
  post_content          String            @db.LongText
  post_title            String            @db.Text
  post_excerpt          String            @db.Text
  post_status           String            @default("publish") @db.VarChar(20)
  comment_status        String            @default("open") @db.VarChar(20)
  ping_status           String            @default("open") @db.VarChar(20)
  post_password         String            @default("") @db.VarChar(255)
  post_name             String            @default("") @db.VarChar(200)
  to_ping               String            @db.Text
  pinged                String            @db.Text
  post_modified         DateTime?         @db.DateTime(0)
  post_modified_gmt     DateTime?         @db.DateTime(0)
  post_content_filtered String            @db.LongText
  post_parent           BigInt            @default(0) @db.UnsignedBigInt
  guid                  String            @default("") @db.VarChar(255)
  menu_order            Int               @default(0)
  post_type             String            @default("post") @db.VarChar(20)
  post_mime_type        String            @default("") @db.VarChar(100)
  comment_count         BigInt            @default(0)
  trip_participant      TripParticipant[]

  @@index([post_author], map: "post_author")
  @@index([post_name(length: 191)], map: "post_name")
  @@index([post_parent], map: "post_parent")
  @@index([post_type, post_status, post_date, ID], map: "type_status_date")
}

model wp_term_relationships {
  object_id        BigInt @default(0) @db.UnsignedBigInt
  term_taxonomy_id BigInt @default(0) @db.UnsignedBigInt
  term_order       Int    @default(0)

  @@id([object_id, term_taxonomy_id])
  @@index([object_id], map: "object_id")
  @@index([term_taxonomy_id], map: "term_taxonomy_id")
}

model wp_term_taxonomy {
  term_taxonomy_id BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  term_id          BigInt @default(0) @db.UnsignedBigInt
  taxonomy         String @default("") @db.VarChar(32)
  description      String @db.LongText
  parent           BigInt @default(0) @db.UnsignedBigInt
  count            BigInt @default(0)

  @@unique([term_id, taxonomy], map: "term_id_taxonomy")
  @@index([taxonomy], map: "taxonomy")
}

model wp_termmeta {
  meta_id    BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  term_id    BigInt  @default(0) @db.UnsignedBigInt
  meta_key   String? @db.VarChar(255)
  meta_value String? @db.LongText

  @@index([meta_key(length: 191)], map: "meta_key")
  @@index([term_id], map: "term_id")
}

model wp_terms {
  term_id    BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  name       String @default("") @db.VarChar(200)
  slug       String @default("") @db.VarChar(200)
  term_group BigInt @default(0)

  @@index([name(length: 191)], map: "name")
  @@index([slug(length: 191)], map: "slug")
}

model wp_usermeta {
  umeta_id   BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  user_id    BigInt  @default(0) @db.UnsignedBigInt
  meta_key   String? @db.VarChar(255)
  meta_value String? @db.LongText

  @@index([meta_key(length: 191)], map: "meta_key")
  @@index([user_id], map: "user_id")
}

model wp_users {
  ID                  BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  user_login          String   @default("") @db.VarChar(60)
  user_pass           String   @default("") @db.VarChar(255)
  user_nicename       String   @default("") @db.VarChar(50)
  user_email          String   @default("") @db.VarChar(100)
  user_url            String   @default("") @db.VarChar(100)
  user_registered     DateTime @default(dbgenerated("('2025-01-01 00:00:00')")) @db.DateTime(0)
  user_activation_key String   @default("") @db.VarChar(255)
  user_status         Int      @default(0)
  display_name        String   @default("") @db.VarChar(250)

  @@index([user_email], map: "user_email")
  @@index([user_login], map: "user_login_key")
  @@index([user_nicename], map: "user_nicename")
}

model listing_to_post {
  id         Int  @id @default(autoincrement())
  listing_id Int?
  post_id    Int?
}

model wp_aiowps_debug_log {
  id      BigInt   @id @default(autoincrement())
  level   String   @default("") @db.VarChar(25)
  message String   @default("") @db.Text
  type    String   @default("") @db.VarChar(25)
  created DateTime @db.DateTime(0)
}

model wp_aiowps_events {
  id           BigInt   @id @default(autoincrement())
  event_type   String   @default("") @db.VarChar(150)
  username     String?  @db.VarChar(150)
  user_id      BigInt?
  event_date   DateTime @db.DateTime(0)
  ip_or_host   String?  @db.VarChar(100)
  referer_info String?  @db.VarChar(255)
  url          String?  @db.VarChar(255)
  country_code String?  @db.VarChar(50)
  event_data   String?  @db.LongText
}

model wp_aiowps_failed_logins {
  id                BigInt   @id @default(autoincrement())
  user_id           BigInt
  user_login        String   @db.VarChar(150)
  failed_login_date DateTime @db.DateTime(0)
  login_attempt_ip  String   @default("") @db.VarChar(100)

  @@index([failed_login_date], map: "failed_login_date")
  @@index([failed_login_date, login_attempt_ip], map: "failed_login_date_and_login_attempt_ip")
  @@index([login_attempt_ip], map: "login_attempt_ip")
}

model wp_aiowps_global_meta {
  meta_id     BigInt   @id @default(autoincrement())
  date_time   DateTime @db.DateTime(0)
  meta_key1   String   @db.VarChar(255)
  meta_key2   String   @db.VarChar(255)
  meta_key3   String   @db.VarChar(255)
  meta_key4   String   @db.VarChar(255)
  meta_key5   String   @db.VarChar(255)
  meta_value1 String   @db.VarChar(255)
  meta_value2 String   @db.Text
  meta_value3 String   @db.Text
  meta_value4 String   @db.LongText
  meta_value5 String   @db.LongText
}

model wp_aiowps_login_activity {
  id            BigInt   @id @default(autoincrement())
  user_id       BigInt
  user_login    String   @db.VarChar(150)
  login_date    DateTime @db.DateTime(0)
  logout_date   DateTime @db.DateTime(0)
  login_ip      String   @default("") @db.VarChar(100)
  login_country String   @default("") @db.VarChar(150)
  browser_type  String   @default("") @db.VarChar(150)
}

model wp_aiowps_login_lockdown {
  id                    BigInt   @id @default(autoincrement())
  user_id               BigInt
  user_login            String   @db.VarChar(150)
  lockdown_date         DateTime @db.DateTime(0)
  release_date          DateTime @db.DateTime(0)
  failed_login_ip       String   @default("") @db.VarChar(100)
  lock_reason           String   @default("") @db.VarChar(128)
  unlock_key            String   @default("") @db.VarChar(128)
  is_lockout_email_sent Boolean  @default(true)
  backtrace_log         String   @default("") @db.Text

  @@index([failed_login_ip], map: "failed_login_ip")
  @@index([is_lockout_email_sent], map: "is_lockout_email_sent")
  @@index([unlock_key], map: "unlock_key")
}

model wp_aiowps_permanent_block {
  id             BigInt   @id @default(autoincrement())
  blocked_ip     String   @default("") @db.VarChar(100)
  block_reason   String   @default("") @db.VarChar(128)
  country_origin String   @default("") @db.VarChar(50)
  blocked_date   DateTime @db.DateTime(0)
  unblock        Boolean  @default(false)

  @@index([blocked_ip], map: "blocked_ip")
}

model wp_commentmeta {
  meta_id    BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  comment_id BigInt  @default(0) @db.UnsignedBigInt
  meta_key   String? @db.VarChar(255)
  meta_value String? @db.LongText

  @@index([comment_id], map: "comment_id")
  @@index([meta_key(length: 191)], map: "meta_key")
}

model wp_comments {
  comment_ID           BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  comment_post_ID      BigInt   @default(0) @db.UnsignedBigInt
  comment_author       String   @db.TinyText
  comment_author_email String   @default("") @db.VarChar(100)
  comment_author_url   String   @default("") @db.VarChar(200)
  comment_author_IP    String   @default("") @db.VarChar(100)
  comment_date         DateTime @default(dbgenerated("('2025-01-01 00:00:00')")) @db.DateTime(0)
  comment_date_gmt     DateTime @default(dbgenerated("('2025-01-01 00:00:00')")) @db.DateTime(0)
  comment_content      String   @db.Text
  comment_karma        Int      @default(0)
  comment_approved     String   @default("1") @db.VarChar(20)
  comment_agent        String   @default("") @db.VarChar(255)
  comment_type         String   @default("comment") @db.VarChar(20)
  comment_parent       BigInt   @default(0) @db.UnsignedBigInt
  user_id              BigInt   @default(0) @db.UnsignedBigInt

  @@index([comment_approved, comment_date_gmt], map: "comment_approved_date_gmt")
  @@index([comment_author_email(length: 10)], map: "comment_author_email")
  @@index([comment_date_gmt], map: "comment_date_gmt")
  @@index([comment_parent], map: "comment_parent")
  @@index([comment_post_ID], map: "comment_post_ID")
  @@index([comment_type], map: "woo_idx_comment_type")
}

model wp_cth_austats {
  ID            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  author_id     BigInt    @db.UnsignedBigInt
  order_id      BigInt    @db.UnsignedBigInt
  child_post_id BigInt?   @db.UnsignedBigInt
  type          String?   @db.VarChar(100)
  total         Decimal   @db.Decimal(13, 4)
  fee_rate      Decimal   @db.Decimal(5, 2)
  fee           Decimal   @db.Decimal(13, 4)
  earning       Decimal   @db.Decimal(13, 4)
  meta          String?   @db.LongText
  year          String?   @db.VarChar(4)
  month         String?   @db.VarChar(2)
  date          DateTime? @db.Date
  time          Int?
  status        Boolean
}

model wp_cth_booking {
  ID         BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  booking_id BigInt  @db.UnsignedBigInt
  room_id    BigInt  @db.UnsignedBigInt
  guest_id   BigInt  @db.UnsignedBigInt
  listing_id BigInt  @db.UnsignedBigInt
  status     Boolean
  date_from  BigInt? @db.UnsignedBigInt
  date_to    BigInt? @db.UnsignedBigInt
  quantity   Int     @db.TinyInt
}

model wp_cth_chat {
  c_id     Int     @id @default(autoincrement()) @db.UnsignedInt
  user_one BigInt  @db.UnsignedBigInt
  user_two BigInt  @db.UnsignedBigInt
  ip       String? @db.VarChar(30)
  time     Int?
}

model wp_cth_chat_reply {
  cr_id      BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  reply      String?  @db.Text
  user_id_fk BigInt   @db.UnsignedBigInt
  ip         String?  @db.VarChar(30)
  time       Int?
  c_id_fk    Int      @db.UnsignedInt
  status     Boolean? @default(false)
}

model wp_cth_lstats {
  ID            BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  post_id       BigInt    @db.UnsignedBigInt
  child_post_id BigInt?   @db.UnsignedBigInt
  type          String?   @db.VarChar(100)
  value         Int
  meta          String?   @db.LongText
  year          String?   @db.VarChar(4)
  month         String?   @db.VarChar(2)
  date          DateTime? @db.Date
  time          Int?
  ip            String?   @db.VarChar(30)
  guest_id      BigInt?   @db.UnsignedBigInt
}

model wp_cth_noti {
  id                  Int     @id @default(autoincrement()) @db.UnsignedInt
  notification_obj_id Int     @db.UnsignedInt
  notifier_id         BigInt  @db.UnsignedBigInt
  status              Boolean
}

model wp_cth_noti_change {
  id                  Int     @id @default(autoincrement()) @db.UnsignedInt
  notification_obj_id Int     @db.UnsignedInt
  actor_id            BigInt  @db.UnsignedBigInt
  status              Boolean
}

model wp_cth_noti_obj {
  id             Int     @id @default(autoincrement()) @db.UnsignedInt
  entity_type_id Int     @db.UnsignedInt
  entity_id      Int     @db.UnsignedInt
  time           Int?
  status         Boolean
}

model wp_cth_wkhours {
  ID      BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  post_id BigInt    @db.UnsignedBigInt
  day     String    @db.VarChar(50)
  day_num Boolean
  static  String    @db.VarChar(100)
  open    DateTime? @db.Time(0)
  close   DateTime? @db.Time(0)
}

model wp_duplicator_packages {
  id      BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  name    String    @db.VarChar(250)
  hash    String    @db.VarChar(50)
  status  Int
  created DateTime? @db.DateTime(0)
  owner   String    @db.VarChar(60)
  package String    @db.LongText

  @@index([hash], map: "hash")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model wp_e_submissions {
  id                      BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  type                    String?  @db.VarChar(255)
  hash_id                 String   @db.VarChar(255)
  main_meta_id            BigInt   @db.UnsignedBigInt
  post_id                 BigInt   @db.UnsignedBigInt
  referer                 String   @db.VarChar(500)
  referer_title           String?  @db.VarChar(300)
  element_id              String   @db.VarChar(255)
  form_name               String   @db.VarChar(255)
  campaign_id             BigInt   @db.UnsignedBigInt
  user_id                 BigInt?  @db.UnsignedBigInt
  user_ip                 String   @db.VarChar(46)
  user_agent              String   @db.Text
  actions_count           Int?     @default(0)
  actions_succeeded_count Int?     @default(0)
  status                  String   @db.VarChar(20)
  is_read                 Boolean  @default(false)
  meta                    String?  @db.Text
  created_at_gmt          DateTime @db.DateTime(0)
  updated_at_gmt          DateTime @db.DateTime(0)
  created_at              DateTime @db.DateTime(0)
  updated_at              DateTime @db.DateTime(0)
}

model wp_e_submissions_actions_log {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  submission_id  BigInt   @db.UnsignedBigInt
  action_name    String   @db.VarChar(255)
  action_label   String?  @db.VarChar(255)
  status         String   @db.VarChar(20)
  log            String?  @db.Text
  created_at_gmt DateTime @db.DateTime(0)
  updated_at_gmt DateTime @db.DateTime(0)
  created_at     DateTime @db.DateTime(0)
  updated_at     DateTime @db.DateTime(0)
}

model wp_e_submissions_values {
  id            BigInt  @id @default(autoincrement()) @db.UnsignedBigInt
  submission_id BigInt  @default(0) @db.UnsignedBigInt
  key           String? @db.VarChar(255)
  value         String? @db.LongText
}

model wp_knowhere_job_listing_post_views {
  id     BigInt  @db.UnsignedBigInt
  type   Boolean
  period String  @db.VarChar(8)
  count  BigInt  @db.UnsignedBigInt

  @@id([type, period, id])
  @@unique([id, type, period, count], map: "id_type_period_count")
  @@index([type, period, count], map: "type_period_count")
}

model wp_links {
  link_id          BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  link_url         String    @default("") @db.VarChar(255)
  link_name        String    @default("") @db.VarChar(255)
  link_image       String    @default("") @db.VarChar(255)
  link_target      String    @default("") @db.VarChar(25)
  link_description String    @default("") @db.VarChar(255)
  link_visible     String    @default("Y") @db.VarChar(20)
  link_owner       BigInt    @default(1) @db.UnsignedBigInt
  link_rating      Int       @default(0)
  link_updated     DateTime? @db.DateTime(0)
  link_rel         String    @default("") @db.VarChar(255)
  link_notes       String    @db.MediumText
  link_rss         String    @default("") @db.VarChar(255)

  @@index([link_visible], map: "link_visible")
}

model wp_litespeed_img_optm {
  id              BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  post_id         BigInt @default(0) @db.UnsignedBigInt
  optm_status     Int    @default(0) @db.TinyInt
  src             String @db.Text
  src_filesize    Int    @default(0)
  target_filesize Int    @default(0)
  webp_filesize   Int    @default(0)

  @@index([optm_status], map: "optm_status")
  @@index([post_id], map: "post_id")
}

model wp_litespeed_img_optming {
  id          BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  post_id     BigInt @default(0) @db.UnsignedBigInt
  optm_status Int    @default(0) @db.TinyInt
  src         String @default("") @db.VarChar(1000)
  server_info String @db.Text

  @@index([optm_status], map: "optm_status")
  @@index([post_id], map: "post_id")
  @@index([src(length: 191)], map: "src")
}

model wp_options {
  option_id    BigInt @id @default(autoincrement()) @db.UnsignedBigInt
  option_name  String @unique(map: "option_name") @default("")
  option_value String @db.LongText
  autoload     String @default("yes") @db.VarChar(20)

  @@index([autoload], map: "autoload")
}

model wp_product_catmeta {
  meta_id        BigInt  @unique(map: "meta_id") @default(autoincrement())
  product_cat_id BigInt  @default(0)
  meta_key       String? @db.VarChar(255)
  meta_value     String? @db.LongText
}
